# Copy to .env.local and adjust.
#
# Which data source the app talks to:
#   local — browser localStorage (default; works with no backend)
#   http  — the Go REST backend (docs/openapi.yaml)
VITE_DATA_SOURCE=local

# Base URL of the Go backend when VITE_DATA_SOURCE=http.
# Leave empty to use same-origin "/api" (works with the Vite dev proxy and
# when the Go server also serves the built SPA).
VITE_API_URL=http://localhost:8080
